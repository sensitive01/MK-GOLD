# Root Gitignore
# -----------------

# Dependencies
node_modules/
**/node_modules/

# Environment Variables
.env
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Build outputs
dist/
build/
**/dist/
**/build/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Large backup files
*.zip
*.tar.gz
*.rar
*.7z

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Other misc caches
.eslintcache
.next/
.serverless/
.output/
